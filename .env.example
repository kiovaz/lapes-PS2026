# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecommerce
DATABASE_URL=postgresql://postgres:postgres@db:5432/ecommerce

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=my-secret-dev-key123
JWT_EXPIRES_IN=7d

# Ports
PORT_API=3000
PORT_POSTGRES=5432
PORT_REDIS=6379
PORT_PRISMA_STUDIO=5555

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cache & Lock TTLs
CACHE_PRODUCTS_LIST_TTL=600
CACHE_PRODUCTS_DETAIL_TTL=900
CHECKOUT_LOCK_TTL_MS=30000
