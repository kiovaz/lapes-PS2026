# Postgres (NeonDB)
DATABASE_URL=postgresql://neondb_owner:password@ep-something.us-east-2.aws.neon.tech/neondb?sslmode=require

# Redis (Upstash)
REDIS_URL=rediss://default:password@something.upstash.io:6379

# JWT
JWT_SECRET=my-secret-dev-key123
JWT_EXPIRES_IN=7d

# Ports
PORT_API=3000
PORT_PRISMA_STUDIO=5555

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cache & Lock TTLs
CACHE_PRODUCTS_LIST_TTL_MS=600000
CACHE_PRODUCTS_DETAIL_TTL_MS=900000
CHECKOUT_LOCK_TTL_MS=30000

# Gemini (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
